# Dependencies (rebuilt in container)
node_modules/

# Build output (rebuilt in container)
app/static/build/

# Python cache
__pycache__/
*.pyc
*.pyo
.pytest_cache/
*.egg-info/
.venv/

# Version control
.git/
.gitignore

# Environment (use container env vars)
.env

# Development files
*.log
*.tmp
*.swp
.vscode/
.idea/
.DS_Store
Thumbs.db

# Documentation
docs/
*.md
!README.md

# Tests (not needed in production image)
tests/
pytest.ini
.coverage
htmlcov/

# Local data (user uploads mounted via volume, not baked into image)
datastore/
